# This file is used as an example for .env.local
# Copy this to .env.local and fill in your values

# Google Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB URI for Elephant Memory (optional, but recommended)
# Without this, the instant scammer blocking feature won't work
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/veritas?appName=Cluster0

# TODO: Replace with TON API - contract audit / risk API key when available
# RUGCHECK_API_KEY=

# --- Demo / Track 2: reliable screenshot evidence in Telegram ---
# Set both for screenshot photo to appear in bot replies.
# VERITAS_SAVE_SCREENSHOTS=true
# VERITAS_PUBLIC_BASE_URL=https://your-app.vercel.app
# Screenshot capture also requires a real project website URL (not t.me/x.com) and SCREENSHOTONE_ACCESS_KEY or Microlink.

# Telegram bot (required for Mini App init validation and for Track 2 bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: secret token for webhook verification (set same value in BotFather / setWebhook)
# TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# Optional: public base URL for bot screenshot links (e.g. https://your-app.vercel.app)
# VERITAS_PUBLIC_BASE_URL=https://your-app.vercel.app
