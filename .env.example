# Copy this file to .env.local and fill in the values you need.

# Required
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Recommended for the full product surface
# Stores prior Veritas records used for drift, repeated-pattern checks, and authority-linked history.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/veritas?appName=Cluster0

# Optional webhook verification for /api/telegram/webhook.
# Set the same value when configuring the Telegram webhook.
# TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# Optional screenshot support for Telegram bot photo replies.
# Set both if you want screenshots saved locally and served from a public deployment.
# VERITAS_SAVE_SCREENSHOTS=true
# VERITAS_PUBLIC_BASE_URL=https://your-app.vercel.app

# Optional screenshot provider key.
# If unset, Veritas can fall back to Microlink when capture is available.
# SCREENSHOTONE_ACCESS_KEY=your_screenshotone_access_key
